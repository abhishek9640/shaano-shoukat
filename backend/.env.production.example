# ── Server ──
NODE_ENV=production
PORT=5000

# ── Database ──
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/shaanoshaukat?retryWrites=true&w=majority

# ── Auth ──
# Generate with: openssl rand -hex 64
JWT_SECRET=<your-64-char-hex-secret>
JWT_EXPIRE=30d

# ── AWS S3 (product image uploads) ──
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-south-1
AWS_S3_BUCKET=shaanoshaukat-uploads

# ── CORS ──
FRONTEND_URL=https://shaanoshaukat.com
